{
  "name": "id",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev:core": "wrangler dev --config workers/core/wrangler.jsonc",
    "dev:ui": "vinext dev --cwd workers/ui",
    "dev:ladle": "ladle serve",
    "dev:stack:core": "wrangler dev -c workers/core/wrangler.jsonc -c workers/ui/wrangler.jsonc",
    "dev:stack:ui": "wrangler dev -c workers/ui/wrangler.jsonc -c workers/core/wrangler.jsonc",
    "build:ladle": "ladle build --outDir .ladle/build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write \"packages/**/*.ts\" \"workers/**/*.ts\" \"!packages/client/src/**\"",
    "format:check": "oxfmt --check \"packages/**/*.ts\" \"workers/**/*.ts\" \"!packages/client/src/**\"",
    "check:dup": "node scripts/check-duplication-threshold.mjs",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm lint && pnpm check:dup && pnpm typecheck && pnpm test",
    "dev:link": "IDCO_LINK=1 pnpm install --no-frozen-lockfile",
    "dev:unlink": "pnpm update @idco/lib @idco/ui",
    "check:lockfile": "node scripts/check-lockfile-clean.mjs",
    "advise": "node scripts/filter-advise.mjs",
    "advise:raw": "aislop scan --exclude node_modules,dist,coverage,.wrangler,migrations && fallow dupes --mode semantic --min-tokens 150 --min-lines 10 --skip-local --ignore-imports --format compact --quiet",
    "advise:aislop": "aislop scan --exclude node_modules,dist,coverage,.wrangler,migrations",
    "advise:dupes": "fallow dupes --mode semantic --min-tokens 150 --min-lines 10 --skip-local --ignore-imports --format compact --quiet",
    "advise:json": "aislop scan --json --exclude node_modules,dist,coverage,.wrangler,migrations",
    "db:generate": "npx @better-auth/cli generate --config workers/core/src/auth/cli.ts --output workers/core/src/db/auth-schema.ts --yes && drizzle-kit generate",
    "db:migration:new": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply id --local --config workers/core/wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply id --remote --config workers/core/wrangler.jsonc",
    "deploy:core": "pnpm build && pnpm deploy:prebuilt:core",
    "deploy:core:dry-run": "pnpm build && pnpm deploy:prebuilt:core:dry-run",
    "deploy:prebuilt:core": "wrangler deploy --config dist/id_core/wrangler.json",
    "deploy:prebuilt:core:dry-run": "wrangler deploy --config dist/id_core/wrangler.json --dry-run --outdir dist/core",
    "deploy:ui": "cd workers/ui && vinext build && wrangler deploy",
    "deploy:ui:dry-run": "cd workers/ui && vinext build && wrangler deploy --dry-run --outdir ../../dist/ui",
    "smoke:remote": "node scripts/remote-smoke.mjs",
    "auth:api": "node scripts/auth-api.mjs",
    "auth:api:login": "node scripts/auth-api-login.mjs",
    "auth:api:logout": "node scripts/auth-api-logout.mjs"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.6.11",
    "@idco/lib": "npm:@quanghuy1242/idco-lib@^0.1.13",
    "@idco/ui": "npm:@quanghuy1242/idco-ui@^0.1.13",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.21",
    "jose": "6.2.3",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-aria": "3.48.0",
    "react-aria-components": "1.17.0",
    "react-dom": "19.2.6",
    "react-stately": "3.46.0",
    "swr": "2.3.6",
    "vinext": "0.0.54",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.2",
    "@cloudflare/vitest-pool-workers": "0.16.7",
    "@cloudflare/workers-types": "4.20260519.1",
    "@ladle/react": "^5.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "aislop": "0.9.0",
    "better-sqlite3": "^12.10.0",
    "daisyui": "^5.5.20",
    "drizzle-kit": "^0.31.10",
    "fallow": "2.75.0",
    "jsdom": "^29.1.1",
    "next": "^16.2.6",
    "oxfmt": "^0.53.0",
    "oxlint": "1.66.0",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6",
    "wrangler": "4.93.0"
  }
}
