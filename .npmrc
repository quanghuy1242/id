# The shared idco design system is published to GitHub Packages under the
# personal scope (@quanghuy1242). Consumers import it as @idco/* through npm
# aliases in package.json (e.g. "@idco/ui": "npm:@quanghuy1242/idco-ui@^0.1.11").
#
# This line tells pnpm where to fetch the @quanghuy1242 scope. CI authenticates
# via actions/setup-node (registry-url + scope + NODE_AUTH_TOKEN); local
# development links the sibling ~/pjs/idco checkout (pnpm dev:link) and needs no
# token because nothing under this scope is fetched in link mode.
@quanghuy1242:registry=https://npm.pkg.github.com
